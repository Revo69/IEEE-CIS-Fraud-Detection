# ==============================================================================
# IEEE-CIS Fraud Detection Pipeline - Airflow Dockerfile
# ==============================================================================
# Этот Dockerfile создает кастомный образ Airflow с нашими зависимостями
#
# Базовый образ: apache/airflow:2.8.1-python3.11
# Добавляем: наши Python библиотеки (DuckDB, Polars, и т.д.)
#
# Build: docker-compose build
# ==============================================================================

# ------------------------------------------------------------------------------
# Базовый образ
# ------------------------------------------------------------------------------
FROM apache/airflow:3.1.7-python3.11

# Официальный образ Apache Airflow
# - Версия Airflow: 3.1.7 (latest stable, Feb 2026)
# - Python: 3.11
# - OS: Debian-based Linux
# - Предустановлены: Airflow, pip, необходимые системные библиотеки
# 
# Airflow 3.x включает:
# - Human-in-the-Loop (HITL) workflows
# - Task SDK для изоляции задач
# - Улучшенный React-based UI
# - Task Isolation для лучшей безопасности

# ------------------------------------------------------------------------------
# Метаданные образа
# ------------------------------------------------------------------------------
LABEL maintainer="sergey.revo@outlook.com"
LABEL project="fraud-detection-pipeline"
LABEL description="Custom Airflow image for IEEE-CIS Fraud Detection Pipeline"

# ------------------------------------------------------------------------------
# Переключаемся на root для установки системных пакетов
# ------------------------------------------------------------------------------
USER root

# Устанавливаем системные зависимости
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        # === Build tools ===
        build-essential \
        # Нужен для компиляции некоторых Python пакетов
        
        # === Network tools ===
        curl \
        wget \
        netcat-traditional \
        # curl/wget - для скачивания файлов
        # netcat - для проверки доступности портов
        
        # === Git ===
        git \
        # Может понадобиться для клонирования репозиториев
        
        # === Utilities ===
        vim \
        nano \
        # Текстовые редакторы (для дебага в контейнере)
        
    # Очищаем кеш apt для уменьшения размера образа
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------------------------
# Создаем необходимые директории
# ------------------------------------------------------------------------------
RUN mkdir -p /opt/airflow/logs \
    && mkdir -p /opt/airflow/dags \
    && mkdir -p /opt/airflow/plugins \
    && mkdir -p /opt/airflow/data \
    && mkdir -p /opt/airflow/src \
    && mkdir -p /opt/airflow/config

# Устанавливаем права доступа
RUN chown -R airflow:root /opt/airflow

# ------------------------------------------------------------------------------
# Переключаемся обратно на airflow пользователя
# ------------------------------------------------------------------------------
USER airflow

# ------------------------------------------------------------------------------
# Копируем requirements файлы
# ------------------------------------------------------------------------------
COPY --chown=airflow:root requirements.txt /opt/airflow/requirements.txt

# --chown=airflow:root - устанавливаем владельца файла
# Важно: файл должен принадлежать airflow пользователю

# ------------------------------------------------------------------------------
# Устанавливаем Python зависимости
# ------------------------------------------------------------------------------
RUN pip install --no-cache-dir --user -r /opt/airflow/requirements.txt

# --no-cache-dir: не сохранять кеш pip (экономим место)
# --user: устанавливать в домашнюю директорию пользователя
# -r: читать зависимости из файла

# Объяснение зависимостей из requirements.txt:
# - pandas, polars - для обработки данных
# - duckdb - быстрая OLAP база данных
# - great-expectations - валидация данных
# - google-cloud-* - интеграция с GCP (Phase 2)
# - и другие (см. requirements.txt)

# ------------------------------------------------------------------------------
# Обновляем pip до последней версии
# ------------------------------------------------------------------------------
RUN pip install --no-cache-dir --user --upgrade pip setuptools wheel

# setuptools, wheel - нужны для сборки некоторых пакетов

# ------------------------------------------------------------------------------
# Настраиваем Python path
# ------------------------------------------------------------------------------
ENV PYTHONPATH="/opt/airflow:${PYTHONPATH}"

# Добавляем /opt/airflow в PYTHONPATH
# Это позволит импортировать наш код: from src.extract import ...

# ------------------------------------------------------------------------------
# Рабочая директория
# ------------------------------------------------------------------------------
WORKDIR /opt/airflow

# Все команды будут выполняться из этой директории

# ------------------------------------------------------------------------------
# Копируем startup скрипт (опционально)
# ------------------------------------------------------------------------------
# Раскомментируйте, если создадите кастомный entrypoint:
# COPY --chown=airflow:root docker/entrypoint.sh /entrypoint.sh
# RUN chmod +x /entrypoint.sh
# ENTRYPOINT ["/entrypoint.sh"]

# ------------------------------------------------------------------------------
# Healthcheck (проверка здоровья контейнера)
# ------------------------------------------------------------------------------
# Встроенный healthcheck от базового образа уже есть
# Но можем добавить свой:
HEALTHCHECK --interval=30s --timeout=10s --retries=3 --start-period=40s \
  CMD airflow jobs check --job-type SchedulerJob --hostname "$${HOSTNAME}" || exit 1

# Проверяет, что Scheduler работает
# --interval: как часто проверять
# --timeout: максимальное время ожидания
# --retries: сколько раз повторить при неудаче
# --start-period: сколько ждать перед первой проверкой

# ------------------------------------------------------------------------------
# Expose ports (документация, Docker сам их не открывает)
# ------------------------------------------------------------------------------
# Webserver
EXPOSE 8080
# Scheduler health endpoint
EXPOSE 8974

# Фактическое открытие портов происходит в docker-compose.yml

# ------------------------------------------------------------------------------
# Метаданные для кеширования Docker слоев
# ------------------------------------------------------------------------------
# Docker кеширует каждый слой (RUN, COPY, и т.д.)
# Если файл не изменился - используется кеш (быстрая сборка)
# Поэтому:
# 1. Сначала копируем requirements.txt (меняется редко)
# 2. Устанавливаем зависимости (долго, но кешируется)
# 3. Потом копируем код (меняется часто, но быстро)

# ------------------------------------------------------------------------------
# Заметки для разработки
# ------------------------------------------------------------------------------
# 
# Как пересобрать образ:
#   docker-compose build
#   docker-compose build --no-cache  # полная пересборка
#
# Как войти в контейнер:
#   docker-compose exec airflow-webserver bash
#
# Как проверить установленные пакеты:
#   docker-compose exec airflow-webserver pip list
#
# Как посмотреть логи:
#   docker-compose logs airflow-webserver
#   docker-compose logs -f airflow-scheduler  # follow режим
#
# Размер образа (~2-3 GB):
#   docker images | grep airflow
#
# ==============================================================================
